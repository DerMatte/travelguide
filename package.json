{
  "name": "travelguide",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm validate:content && next build",
    "start": "next start",
    "lint": "eslint",
    "validate:content": "tsx scripts/validate-airports.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:dev": "tsx scripts/dev-postgres.ts",
    "generate:airport": "tsx --env-file-if-exists=.env.local scripts/generate-airport.ts",
    "generate:airports": "tsx --env-file-if-exists=.env.local scripts/generate-airports-batch.ts",
    "generate:lounges": "tsx --env-file-if-exists=.env.local scripts/generate-lounges.ts",
    "review:airports": "tsx --env-file-if-exists=.env.local scripts/review-airport-pages.ts",
    "sync:forum": "tsx --env-file-if-exists=.env.local scripts/sync-community-forum.ts"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.120",
    "@ai-sdk/openai": "^3.0.65",
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^2.0.1",
    "ai": "^6.0.191",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "lz-string": "^1.5.0",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.8.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cursor/sdk": "^1.0.13",
    "@tailwindcss/postcss": "^4",
    "@types/lz-string": "^1.5.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "embedded-postgres": "18.4.0-beta.17",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sqlite3",
      "esbuild",
      "sharp",
      "embedded-postgres",
      "@embedded-postgres/linux-arm64",
      "@embedded-postgres/linux-x64",
      "@embedded-postgres/darwin-arm64"
    ]
  }
}
